<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Bit Payment Tests" verbose="2">
    <listeners>
        <listener class-name="com.example.bit.listener.SoftAssertListener"/>
    </listeners>

    <!-- UI Tests -->
    <test name="Money Approval UI Tests">
        <classes>
            <class name="com.example.bit.tests.ui.ApprovalMoneyUITest">
                <methods>
                    <include name="testApprovalPopupIsDisplayed"/>
                    <include name="testClickApproveTransferButton"/>
                    <include name="testConfirmationMessageIsDisplayed"/>
                    <include name="testCompleteApprovalFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- API Tests -->
    <test name="Payment Request API Tests">
        <classes>
            <class name="com.example.bit.tests.BitApplicationTests"/>
        </classes>
    </test>
</suite>